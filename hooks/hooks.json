{
  "SessionStart": [
    {
      "matcher": "startup",
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/method-status-line.sh" }
      ]
    },
    {
      "matcher": "resume",
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/method-status-line.sh" }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Skill|Bash",
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/etapa-gate.sh" }
      ]
    }
  ]
}
